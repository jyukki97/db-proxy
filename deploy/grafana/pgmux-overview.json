      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(pgmux_reader_fallback_total[$__rate_interval])",
          "legendFormat": "fallback/s",
          "refId": "A"
        }
      ]
    },

    {
      "collapsed": false,
